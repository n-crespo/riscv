# --- Project Configuration ---

top_module := "top"
project_name := "riscv_uart_test"
rtl_dir := "rtl"
tb_dir := "tb"
sw_dir := "sw"
build_dir := sw_dir + "/.build"
tcl_dir := "../../tcl"

# --- Toolchain ---

rv_prefix := "riscv64-unknown-elf-"
as := rv_prefix + "as"
objcopy := rv_prefix + "objcopy"
as_flags := "-march=rv32i -mabi=ilp32"
objcopy_flags := "-O verilog --verilog-data-width=4"

# --- Simulator ---

iverilog := "iverilog"
vvp := "vvp"

# --- Simulation ---
# Run an assembly file from sw/, with optional testbench override
# Usage: just run fib           → uses tb/fib.v if exists, else tb/inspect.v
#        just run fib inspect   → forces tb/inspect.v

run sw_file tb_file="":
    #!/usr/bin/env bash
    set -e
    mkdir -p {{ build_dir }}

    full_path="{{ sw_dir }}/{{ sw_file }}.s"
    hex_path="{{ build_dir }}/{{ sw_file }}.hex"
    obj_path="{{ build_dir }}/{{ sw_file }}.o"
    vvp_bin="{{ build_dir }}/{{ sw_file }}.vvp"
    vcd_file="{{ build_dir }}/{{ sw_file }}.vcd"

    # resolve testbench
    if [ -n "{{ tb_file }}" ]; then
        tb="{{ tb_dir }}/{{ tb_file }}.v"
    elif [ -f "{{ tb_dir }}/{{ sw_file }}.v" ]; then
        tb="{{ tb_dir }}/{{ sw_file }}.v"
    else
        tb="{{ tb_dir }}/inspect.v"
    fi

    echo "[ASM] Assembling $full_path..."
    {{ as }} {{ as_flags }} "$full_path" -o "$obj_path"
    {{ objcopy }} {{ objcopy_flags }} "$obj_path" "$hex_path"

    echo "[SIM] Running $full_path against $tb..."
    # VCD_NAME macro indicates where dump waveform
    {{ iverilog }} -DSIM_HEX=\"$hex_path\" -DVCD_NAME=\"$vcd_file\" -o "$vvp_bin" {{ rtl_dir }}/*.v "$tb"
    {{ vvp }} "$vvp_bin"

# Run the main testbench
test:
    just run tb

# Cleanup build artifacts
clean:
    rm -rf {{ build_dir }} {{ build_dir }} .Xil *.log *.jou *.pb xsim.dir
    find . -type f \( -name "*.o" -o -name "*.hex" -o -name "*.vvp" -o -name "*.vcd" \) -delete

# -------------------------------------------------------------------------
# FPGA / Vivado Targets
# -------------------------------------------------------------------------

vivado_path := "C:/AMDDesignTools/2025.2/Vivado/bin/vivado.bat"

project:
    @echo "[INFO] Creating Vivado Project..."
    "{{ vivado_path }}" -mode batch -notrace -source {{ tcl_dir }}/create_project.tcl -tclargs {{ project_name }} {{ top_module }} {{ build_dir }} {{ rtl_dir }}

bitstream:
    @echo "[INFO] Generating Bitstream..."
    "{{ vivado_path }}" -mode batch -notrace -source {{ tcl_dir }}/run_bitstream.tcl -tclargs {{ project_name }} {{ build_dir }}

program:
    @echo "[INFO] Programming FPGA..."
    "{{ vivado_path }}" -mode batch -notrace -source {{ tcl_dir }}/program.tcl -tclargs {{ project_name }} {{ top_module }} {{ build_dir }}

gui:
    "{{ vivado_path }}" -mode gui {{ build_dir }}/{{ project_name }}.xpr &
